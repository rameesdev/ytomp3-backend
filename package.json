{
  "name": "ytomp3",
  "version": "1.0.0",
  "description": "Massive SEO-focused YouTube to MP3 Converter and Music Platform",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev": "nodemon --ignore public --ignore temp --ignore uploads --ignore scratch --ignore node_modules server/app.js",
    "worker": "node server/workers/index.js",
    "all": "concurrently \"npm run start\" \"npm run worker\""
  },
  "keywords": [
    "ytomp3",
    "youtube to mp3",
    "yt to mp3",
    "mp3 converter",
    "youtube mp3 downloader"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "axios": "^1.6.8",
    "bullmq": "^5.8.1",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.4.0",
    "node-cron": "^3.0.3",
    "play-dl": "^1.9.7",
    "slugify": "^1.6.6",
    "youtube-mp3-downloader": "^0.7.11",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
