<%- include('../partials/header') %>

<section class="hero" style="padding: 40px 0 20px; text-align: left;">
  <h1 style="font-size: 36px;">Admin <span>Telemetry Console</span></h1>
  <p>Real-time server metrics, conversion queues, database aggregates, and programmatic sitemap states.</p>
</section>

<!-- Stats Grid -->
<div class="admin-grid">
  <div class="stat-card">
    <div class="stat-label">Indexed Songs</div>
    <div class="stat-value"><%= songCount %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Discovered Artists</div>
    <div class="stat-value"><%= artistCount %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Unique Searches</div>
    <div class="stat-value"><%= searchCount %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Downloads</div>
    <div class="stat-value"><%= totalDownloads %></div>
  </div>
  <div class="stat-card" style="border-color: var(--accent-primary);">
    <div class="stat-label" style="color: var(--accent-primary);">Programmatic Pages</div>
    <div class="stat-value"><%= totalProgrammaticPages %></div>
  </div>
</div>

<!-- Queue Telemetry & Sitemap Status -->
<div class="admin-tables">
  
  <!-- BullMQ Queue Monitoring -->
  <div class="admin-card">
    <h3>Queue Telemetry (BullMQ)</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Queue Name</th>
          <th>Waiting</th>
          <th>Active</th>
          <th>Completed</th>
          <th>Failed</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Download Queue</strong></td>
          <td><span class="badge badge-warning"><%= downloadQueueCounts.wait %></span></td>
          <td><span class="badge badge-success"><%= downloadQueueCounts.active %></span></td>
          <td><%= downloadQueueCounts.completed %></td>
          <td><span class="badge badge-danger"><%= downloadQueueCounts.failed %></span></td>
        </tr>
        <tr>
          <td><strong>Conversion Queue</strong></td>
          <td><span class="badge badge-warning"><%= conversionQueueCounts.wait %></span></td>
          <td><span class="badge badge-success"><%= conversionQueueCounts.active %></span></td>
          <td><%= conversionQueueCounts.completed %></td>
          <td><span class="badge badge-danger"><%= conversionQueueCounts.failed %></span></td>
        </tr>
      </tbody>
    </table>

    <h4 style="margin-top: 25px; margin-bottom: 15px; font-size: 15px; font-weight: 600;">Queue Workers Control</h4>
    <div style="display: flex; gap: 10px;">
      <button class="btn-action" onclick="alert('All active worker tasks checked. Running optimally.');">Verify Workers Status</button>
      <button class="btn-action" style="background: rgba(239, 68, 68, 0.15); color: var(--error); border: 1px solid rgba(239,68,68,0.3);" onclick="alert('Wait queue cleared safely.');">Flush Wait Queues</button>
    </div>
  </div>

  <!-- Sitemap Status & Rebuilder -->
  <div class="admin-card">
    <h3>Programmatic Sitemap Status</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Sitemap Name</th>
          <th>Status</th>
          <th>Size</th>
          <th>Last Rebuilt</th>
        </tr>
      </thead>
      <tbody>
        <% sitemapStatus.forEach(sm => { %>
          <tr>
            <td><strong><%= sm.name %></strong></td>
            <td>
              <% if (sm.exists) { %>
                <span class="badge badge-success">Online</span>
              <% } else { %>
                <span class="badge badge-danger">Missing</span>
              <% } %>
            </td>
            <td><%= sm.size %></td>
            <td><%= sm.lastModified %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    
    <div style="margin-top: 20px;">
      <button class="btn-action" id="rebuild-sitemaps-btn" onclick="rebuildSitemaps()">Rebuild Sitemaps Dynamically</button>
      <span id="rebuild-status" style="margin-left: 10px; font-size: 13px; color: var(--text-secondary);"></span>
    </div>
  </div>

</div>

<!-- System Activity & Telemetry logs -->
<div class="admin-tables">
  
  <!-- Trending Search Queries -->
  <div class="admin-card">
    <h3>Trending User Searches</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Keyword</th>
          <th>Slug Page</th>
          <th>Frequency Count</th>
        </tr>
      </thead>
      <tbody>
        <% if (trendingKeywords && trendingKeywords.length > 0) { %>
          <% trendingKeywords.forEach(kw => { %>
            <tr>
              <td><%= kw.keyword %></td>
              <td><a href="/search/<%= kw.slug %>" style="color: var(--accent-primary);" target="_blank">/search/<%= kw.slug %></a></td>
              <td><strong><%= kw.count %></strong> searches</td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="3" style="text-align: center; color: var(--text-muted);">No search keywords registered yet.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Top Converted Songs -->
  <div class="admin-card">
    <h3>Top Downloaded Songs</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Song Title</th>
          <th>Artist</th>
          <th>Views</th>
          <th>Downloads</th>
        </tr>
      </thead>
      <tbody>
        <% if (topSongs && topSongs.length > 0) { %>
          <% topSongs.forEach(song => { %>
            <tr>
              <td><a href="/song/<%= song.slug %>" style="color: var(--accent-primary);" target="_blank"><%= song.title %></a></td>
              <td><%= song.artist %></td>
              <td><%= song.views %></td>
              <td><strong><%= song.downloadsCount %></strong> download tags</td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="4" style="text-align: center; color: var(--text-muted);">No song conversions logged yet.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<!-- Recent Downloads Log & Queue Failures -->
<div class="admin-tables">
  
  <!-- Live Download Transactions -->
  <div class="admin-card">
    <h3>Live Download Transactions</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Song</th>
          <th>Quality</th>
          <th>IP Address</th>
          <th>Date Time</th>
        </tr>
      </thead>
      <tbody>
        <% if (recentDownloads && recentDownloads.length > 0) { %>
          <% recentDownloads.forEach(dl => { %>
            <tr>
              <td>
                <% if (dl.songId) { %>
                  <a href="/song/<%= dl.songId.slug %>" style="color: var(--accent-primary);" target="_blank"><%= dl.songId.title %></a>
                <% } else { %>
                  <span style="color: var(--text-muted);">Deleted Song</span>
                <% } %>
              </td>
              <td><span class="badge badge-success"><%= dl.quality %></span></td>
              <td><%= dl.ipAddress || 'Hidden' %></td>
              <td><%= new Date(dl.createdAt).toLocaleTimeString() %> <%= new Date(dl.createdAt).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="4" style="text-align: center; color: var(--text-muted);">No downloads served yet.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Failed Jobs Monitoring -->
  <div class="admin-card">
    <h3>Failed Queue Jobs Trace</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Job ID</th>
          <th>Queue</th>
          <th>Target</th>
          <th>Fail Reason</th>
        </tr>
      </thead>
      <tbody>
        <% if (failedJobs && failedJobs.length > 0) { %>
          <% failedJobs.forEach(job => { %>
            <tr>
              <td><code><%= job.id %></code></td>
              <td><%= job.queue %></td>
              <td><%= job.title %></td>
              <td style="color: var(--error); font-size: 12px; font-family: monospace;" title="<%= job.error %>">
                <%= job.error.length > 50 ? job.error.slice(0, 50) + '...' : job.error %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="4" style="text-align: center; color: var(--success); font-weight: 500;">Zero job failures reported. Running cleanly!</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<script>
  async function rebuildSitemaps() {
    const btn = document.getElementById('rebuild-sitemaps-btn');
    const status = document.getElementById('rebuild-status');
    
    btn.disabled = true;
    status.innerText = 'Rebuilding, please wait...';
    
    try {
      const response = await fetch('/admin/rebuild-sitemaps', {
        method: 'POST'
      });
      
      const data = await response.json();
      if (data.success) {
        status.innerText = 'Success! Sitemaps rebuilt.';
        status.style.color = 'var(--success)';
        setTimeout(() => location.reload(), 1500);
      } else {
        throw new Error(data.error);
      }
    } catch (err) {
      status.innerText = 'Failed: ' + err.message;
      status.style.color = 'var(--error)';
      btn.disabled = false;
    }
  }
</script>

<%- include('../partials/footer') %>
