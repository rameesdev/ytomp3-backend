<%- include('partials/header') %>

<section class="hero" style="padding: 50px 0 30px; text-align: left;">
  <h1 style="font-size: 38px;"><span><%= title %></span> Charts</h1>
  <p><%= description %></p>
</section>

<!-- Songs list -->
<section style="margin-bottom: 50px;">
  <h2 class="section-title">Popular MP3 Conversions</h2>
  
  <% if (songs && songs.length > 0) { %>
    <div class="music-grid">
      <% songs.forEach((song, index) => { %>
        <div class="music-card">
          <!-- Rank Badge -->
          <div style="position: absolute; top: 12px; left: 12px; background: var(--accent-primary); color: #fff; font-weight: 800; font-size: 12px; padding: 2px 8px; border-radius: 4px; z-index: 10;">
            #<%= index + 1 %>
          </div>
          <div class="card-img-wrap" style="padding-top: 5px;">
            <img src="<%= song.thumbnail %>" alt="<%= song.title %> MP3" loading="lazy">
          </div>
          <div class="card-title" title="<%= song.title %>" style="margin-top: 5px;"><%= song.title %></div>
          <div class="card-artist" title="<%= song.artist %>"><%= song.artist %></div>
          <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 8px;">
            <span>👁️ <%= song.views || 0 %> views</span>
            <span style="margin-left: 10px;">⬇️ <%= song.downloadsCount || 0 %> downloads</span>
          </div>
          <a href="/song/<%= song.slug %>" class="card-btn">Download MP3</a>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div style="text-align: center; padding: 40px; border: 1px dashed var(--border-color); border-radius: var(--border-radius-md);">
      <p style="color: var(--text-secondary);">No converted songs are registered in the charts yet. Be the first to convert a track from the homepage!</p>
      <a href="/" class="btn-convert" style="display: inline-block; margin-top: 15px; padding: 10px 20px;">Go to Homepage</a>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
